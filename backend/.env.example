# ─── Admin ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=VisitAddis@Organizer

# ─── Event details (used in notification messages) ───────────────────
EVENT_DATE=Saturday, 12 July 2025
EVENT_LOCATION=National Museum of Ethiopia, Addis Ababa

# ─── Email notifications via Resend (https://resend.com — 3,000/mo free) ──
# 1. Sign up at resend.com and verify a domain (or use the shared domain for testing)
# 2. Create an API key and paste it below
# 3. Set EMAIL_FROM to your verified sender address
#
# If RESEND_API_KEY is not set, email notifications are silently skipped.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Photography Master Class <noreply@yourdomain.com>

# ─── SMS notifications via Africa's Talking (https://africastalking.com) ──
# Covers Ethiopia. Free sandbox for testing — messages don't reach real phones
# but you can verify delivery reports in the AT dashboard.
#
# 1. Sign up at africastalking.com
# 2. For testing: AT_USERNAME=sandbox  (no real SMS sent, free)
#    For production: AT_USERNAME=your-account-username
# 3. Find your API key in the AT dashboard (Settings → API Key)
# 4. AT_SENDER_ID is optional — a registered alphanumeric sender name (e.g. VisitAddis)
#
# If AT_API_KEY is not set, SMS notifications are silently skipped.
AT_USERNAME=sandbox
AT_API_KEY=your-sandbox-or-live-api-key
AT_SENDER_ID=

# ─── Database (auto-detected) ─────────────────────────────────────────
# Locally: uses SQLite (no setup needed)
# On Render: set DATABASE_URL to your PostgreSQL connection string
# DATABASE_URL=postgresql://user:pass@host/dbname
